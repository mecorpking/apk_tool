{
  "name": "apk-tool",
  "version": "1.0.0",
  "description": "Cross-platform AAB to APK converter with device installation",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "package:mac": "electron-vite build && electron-builder --mac --config electron-builder.config.js",
    "package:win": "electron-vite build && electron-builder --win --config electron-builder.config.js"
  },
  "dependencies": {
    "extract-zip": "^2.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  }
}
